# Switch to the OpenAI compatible routing
LLM_BACKEND=openai_compatible
MODEL_NAME=deepseek-ai/deepseek-r1-0528-maas
LLM_TEMPERATURE=0

# Vertex AI settings (Kept for reference)
VERTEXAI_PROJECT=
VERTEXAI_LOCATION=us-central1

# The new routing URL we discovered in the docs!
OPENAI_API_BASE=https://us-central1-aiplatform.googleapis.com/v1/projects//locations/us-central1/endpoints/openapi

# Your Google Auth Token goes here (See note below!)
OPENAI_API_KEY=YOUR_GOOGLE_AUTH_TOKEN
GEMINI_API_KEY=


